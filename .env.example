# Copy to .env (gitignored) and fill in real values.
# Never commit the populated .env file.

# --- WiGLE.net (https://wigle.net/account) ---
WIGLE_NAME=                    # API name (starts with "AID...")
WIGLE_TOKEN=                   # API token
# Live per-user density enrichment at plan time (DECISIONS.md 2026-07-05 enrich).
# WiGLE is ~1 req/sec, so bound how much a single plan spends querying it live.
LIVE_DENSITY_CELL_CAP=8        # max cells a plan density-queries live (nearest first)
LIVE_DENSITY_BUDGET_S=20       # wall-clock seconds cap on live density queries per plan

# --- WDGoWars (https://wdgwars.pl/profile) ---
WDGOWARS_NAME=                 # your in-game username
WDGOWARS_TOKEN=                # API token
WDGOWARS_EXPECTED_VERSION=1.3.0  # precheck warns if the live /api/stats.version differs

# --- OpenRouteService (https://openrouteservice.org/dev/#/signup) ---
ORS_API_KEY=                   # shared routing key: backs web users who have no ORS key of their own
MAPBOX_API_KEY=                # optional fallback when ORS is down or quota hit
# Stateless-tier shared-ORS guard (DECISIONS.md 2026-07-04). Bound the operator's
# exposure when web users fall back to the shared ORS key above.
ORS_SHARED_DAILY_CAP=600       # max shared-ORS ROUTING actions per UTC day (free tier is 2000 ops/day)
ORS_SHARED_RATE_PER_MIN=8      # max shared-ORS ROUTING ops per minute per client IP
ORS_SHARED_GEOCODE_RATE_PER_MIN=40  # shared-ORS GEOCODE (address search) reqs/min per IP; separate window, no daily cap

# --- Push notifications (Phase 5 + 6b.2; optional) ---
# Leave NTFY_TOPIC blank to disable. On public ntfy.sh, anyone with the topic
# name can subscribe to your pushes, so pick a long random one. For self-hosted
# or private servers, override NTFY_BASE_URL and set NTFY_AUTH_TOKEN.
NTFY_TOPIC=                    # leave blank to disable
NTFY_BASE_URL=https://ntfy.sh  # override for self-hosted
NTFY_AUTH_TOKEN=               # only for private/self-hosted ntfy
NTFY_NOTIFY_RUN=true           # push on CSV upload complete (Phase 5)
NTFY_NOTIFY_PLAN=false         # (future) push on plan complete
NTFY_NOTIFY_QUOTA=false        # (future) push on WiGLE/ORS daily quota low
NTFY_DEPARTURE_LEAD_MIN=5      # Phase 6b.2: fire 'time to leave' alarm N min ahead

# --- Opt-in end-to-end-encrypted config sync (DECISIONS.md 2026-07-04 sync) ---
# The /sync endpoint stores opaque encrypted blobs (the server can't read them).
# These bound its abuse surface. Defaults are fine for most deployments.
SYNC_MAX_BYTES=16384           # max encrypted config size accepted
SYNC_RATE_PER_MIN=20           # max /sync reads+writes per minute per client IP

# --- Web (used by notifications for click-through links) ---
WEB_BASE_URL=                  # e.g. https://warroute.darkhorseinfosec.com

# --- Access control ---
# Comma-separated X-Forwarded-User identities (basic_auth usernames or Cloudflare
# Access emails) that see the admin-only "Server config" section on /settings.
# Everyone else is a tester. Blank = no admins. Auth itself lives at Caddy, not here.
ADMIN_USERS=                   # e.g. you@example.com under Cloudflare Access

# --- Deployment ---
HETZNER_IP_ADDR=               # prod box IP

# --- Home base ---
# Used ONLY by operator-side CLI coverage-grid painting. The web tier never renders
# this (each user's home lives in their browser). Default is a neutral point; set
# your real home here only if you run `warroute coverage refresh`.
HOME_LAT=39.8283
HOME_LON=-98.5795
HOME_RADIUS_KM=50
DEFAULT_DURATION_MIN=90

# --- Run review exposure (privacy) ---
# /runs and /runs/{id}/observations.geojson serve exact scanned-AP coordinates,
# including your home network's location. Keep false on any public deployment. Set
# true ONLY on a trusted deployment gated by auth (basic_auth / Cloudflare Access).
EXPOSE_RUN_DATA=false

# --- Paths (prod = absolute under /var; dev = relative to repo) ---
DATABASE_URL=sqlite:///warroute.db
SPOOL_DIR=./spool/in
GPX_OUT_DIR=./gpx-out

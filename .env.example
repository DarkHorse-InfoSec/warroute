# Copy to .env (gitignored) and fill in real values.
# Never commit the populated .env file.

# --- WiGLE.net (https://wigle.net/account) ---
WIGLE_NAME=                    # API name (starts with "AID...")
WIGLE_TOKEN=                   # API token

# --- WDGoWars (https://wdgwars.pl/profile) ---
WDGOWARS_NAME=                 # your in-game username
WDGOWARS_TOKEN=                # API token

# --- OpenRouteService (https://openrouteservice.org/dev/#/signup) ---
ORS_API_KEY=                   # required for routing/optimization
MAPBOX_API_KEY=                # optional fallback when ORS is down or quota hit

# --- Push notifications (Phase 5, optional) ---
NTFY_TOPIC=                    # leave blank to disable

# --- Deployment ---
HETZNER_IP_ADDR=               # prod box IP

# --- Home base (defaults; overrideable per-plan) ---
HOME_LAT=44.9367
HOME_LON=-72.2051
HOME_RADIUS_KM=50
DEFAULT_DURATION_MIN=90

# --- Paths (prod = absolute under /var; dev = relative to repo) ---
DATABASE_URL=sqlite:///warroute.db
SPOOL_DIR=./spool/in
GPX_OUT_DIR=./gpx-out


NTFY_TOPIC=
NTFY_BASE_URL=https://ntfy.sh
NTFY_AUTH_TOKEN=
NTFY_NOTIFY_RUN=true
NTFY_NOTIFY_PLAN=false
NTFY_NOTIFY_QUOTA=false
WEB_BASE_URL=